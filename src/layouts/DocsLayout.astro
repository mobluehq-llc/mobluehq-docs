---
import "../styles/global.css";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
const title = frontmatter.title + " · blueForge docs";

const nav = [
  {
    label: "Quickstart",
    links: [
      { href: "/quickstart", text: "Overview" },
      { href: "/quickstart/blue", text: "Blue" },
      { href: "/quickstart/bluemoat", text: "blueMoat" },
      { href: "/quickstart/bluechart", text: "blueChart" },
      { href: "/quickstart/bluecheck-sdk", text: "blueCheck SDK" },
      { href: "/quickstart/blueglu", text: "blueGlu" },
      { href: "/quickstart/slumbernet", text: "slumberNet" },
    ],
  },
  {
    label: "Getting started",
    links: [
      { href: "/getting-started/install", text: "Install blueForge" },
      { href: "/getting-started/first-dispatch", text: "First dispatch" },
      { href: "/getting-started/licensing", text: "Activation & licensing" },
      { href: "/getting-started/beta-known-issues", text: "Beta & known issues" },
      { href: "/getting-started/support", text: "Support" },
      { href: "/getting-started/troubleshooting", text: "Troubleshooting" },
    ],
  },
  {
    label: "Concepts",
    links: [
      { href: "/concepts/smith-and-apprentice", text: "Smith & Apprentice" },
      { href: "/concepts/verification", text: "Verification" },
      { href: "/concepts/offline-and-privacy", text: "Offline & privacy" },
      { href: "/concepts/receipt-log", text: "Receipt log" },
      { href: "/concepts/slumbernet", text: "slumberNet" },
    ],
  },
  {
    label: "How-to",
    links: [
      { href: "/how-to/set-up-providers", text: "Set up providers" },
      { href: "/how-to/use-council-mode", text: "Council mode" },
      { href: "/how-to/verify-receipts", text: "Verify receipts" },
      { href: "/how-to/export-receipts", text: "Export receipts" },
      { href: "/how-to/report-bugs", text: "Report bugs" },
    ],
  },
  {
    label: "Reference",
    links: [
      { href: "/reference/glossary", text: "Glossary" },
      { href: "/reference/settings", text: "Settings" },
      { href: "/reference/verification-block", text: "Verification block" },
      { href: "/reference/keyboard-shortcuts", text: "Keyboard shortcuts" },
    ],
  },
  {
    label: "Trust",
    links: [{ href: "/trust", text: "Trust center" }],
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {frontmatter.description && (
      <meta name="description" content={frontmatter.description} />
    )}
  </head>
  <body>
    <header class="top">
      <a class="brand" href="/">blueForge docs</a>
      <nav class="topnav">
        <a href="/quickstart">Quickstart</a>
        <a href="/getting-started/install">Get started</a>
        <a href="/concepts/smith-and-apprentice">Concepts</a>
        <a href="/how-to/set-up-providers">How-to</a>
        <a href="/reference/glossary">Reference</a>
        <a href="/trust">Trust</a>
        <a href="https://mobluehq-status.pages.dev">Status</a>
      </nav>
    </header>
    <div class="shell">
      <aside class="sidebar" aria-label="Documentation">
        {
          nav.map((section) => (
            <div class="sidebar-section">
              <p class="sidebar-label">{section.label}</p>
              <ul>
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class:list={[
                        currentPath === link.href.replace(/\/$/, "") && "active",
                      ]}
                    >
                      {link.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </aside>
      <main class="doc">
        <h1>{frontmatter.title}</h1>
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>
    <footer class="foot">
      <a href="https://github.com/mobluehq-llc">MOBLUEHQ on GitHub</a>
    </footer>
  </body>
</html>
